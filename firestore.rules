rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function isSelf(userId) {
      return signedIn() && request.auth.uid == userId;
    }

    function unchangedProtectedFields() {
      return !request.resource.data.diff(resource.data).affectedKeys()
        .hasAny(['id', 'role', 'createdAt']);
    }

    function validBaseProfile(userId, role) {
      return isSelf(userId)
        && request.resource.data.id == userId
        && request.resource.data.role == role
        && request.resource.data.email is string
        && request.resource.data.name is string
        && request.resource.data.lastName is string
        && request.resource.data.createdAt is string;
    }

    function isPatientCaregiver(patientId) {
      return signedIn() && 
        exists(/databases/$(database)/documents/patients/$(patientId)) &&
        get(/databases/$(database)/documents/patients/$(patientId)).data.caregiverId == request.auth.uid;
    }

    function caregiverLinkUpdateOnly() {
      return signedIn()
        && (!('caregiverId' in resource.data) || resource.data.caregiverId == null)
        && request.resource.data.caregiverId == request.auth.uid
        && request.resource.data.linkedCaregiverAt is string
        && request.resource.data.diff(resource.data).affectedKeys()
          .hasOnly(['caregiverId', 'linkedCaregiverAt']);
    }

    match /patients/{patientId} {
      allow create: if validBaseProfile(patientId, 'patient');
      allow read: if isSelf(patientId)
        || (signedIn() && resource.data.caregiverId == request.auth.uid);
      allow update: if (isSelf(patientId) && unchangedProtectedFields())
        || caregiverLinkUpdateOnly();
      allow delete: if false;
    }

    match /caregivers/{caregiverId} {
      allow create: if validBaseProfile(caregiverId, 'caregiver');
      allow read: if isSelf(caregiverId);
      allow update: if isSelf(caregiverId) && unchangedProtectedFields();
      allow delete: if false;
    }

    match /checkIns/{checkInId} {
      allow create, update: if signedIn() && request.resource.data.patientId == request.auth.uid;
      allow read: if signedIn() && (resource.data.patientId == request.auth.uid || isPatientCaregiver(resource.data.patientId));
    }

    match /streaks/{patientId} {
      allow read: if isSelf(patientId) || isPatientCaregiver(patientId);
      allow write: if isSelf(patientId);
    }

    match /achievements/{achievementId} {
      allow create, update: if signedIn() && request.resource.data.patientId == request.auth.uid;
      allow read: if signedIn() && (resource.data.patientId == request.auth.uid || isPatientCaregiver(resource.data.patientId));
    }

    match /appointments/{appointmentId} {
      allow create, update: if signedIn() && (request.resource.data.patientId == request.auth.uid || request.resource.data.caregiverId == request.auth.uid);
      allow delete: if signedIn() && (resource.data.patientId == request.auth.uid || resource.data.caregiverId == request.auth.uid);
      allow read: if signedIn() && (resource.data.patientId == request.auth.uid || resource.data.caregiverId == request.auth.uid);
    }

    match /dailyGoals/{goalId} {
      allow create, update: if signedIn() && (request.resource.data.patientId == request.auth.uid || isPatientCaregiver(request.resource.data.patientId));
      allow read: if signedIn() && (resource.data.patientId == request.auth.uid || isPatientCaregiver(resource.data.patientId));
    }

    match /meditationExercises/{exerciseId} {
      allow read: if signedIn();
      allow write: if signedIn();
    }

    match /completedMeditations/{completionId} {
      allow create, update: if signedIn() && request.resource.data.patientId == request.auth.uid;
      allow read: if signedIn() && (resource.data.patientId == request.auth.uid || isPatientCaregiver(resource.data.patientId));
    }

    match /diaryEntries/{entryId} {
      allow create, update: if signedIn() && request.resource.data.patientId == request.auth.uid;
      allow read: if signedIn() && (resource.data.patientId == request.auth.uid || isPatientCaregiver(resource.data.patientId));
    }

    match /bindingCodes/{bindingCodeId} {
      allow create: if signedIn()
        && request.resource.data.patientId == request.auth.uid
        && request.resource.data.code is string
        && request.resource.data.expiresAt is timestamp;
      allow read: if signedIn();
      allow update: if signedIn()
        && (!('caregiverId' in resource.data) || resource.data.caregiverId == null)
        && request.resource.data.caregiverId == request.auth.uid
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['caregiverId']);
      allow delete: if signedIn()
        && (resource.data.patientId == request.auth.uid || resource.data.caregiverId == request.auth.uid);
    }

    match /alerts/{alertId} {
      allow create: if signedIn()
        && (request.resource.data.patientId == request.auth.uid || request.resource.data.caregiverId == request.auth.uid);
      allow read, update: if signedIn()
        && (resource.data.patientId == request.auth.uid || resource.data.caregiverId == request.auth.uid);
      allow delete: if false;
    }

    match /lumiSessions/{sessionId} {
      allow create, update: if signedIn() && request.resource.data.patientId == request.auth.uid;
      allow read: if signedIn() && (resource.data.patientId == request.auth.uid || isPatientCaregiver(resource.data.patientId));
      allow delete: if signedIn() && request.resource.data.patientId == request.auth.uid;
      
      match /messages/{messageId} {
        allow read, write: if signedIn();
      }
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
